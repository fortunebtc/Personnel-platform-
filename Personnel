<!DOCTYPE html>
<html>
<head>
  <title>AI LMS</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<header>🚀 AI LMS Platform</header>

<div class="container">

  <div class="sidebar">
    <button onclick="show('dashboard')">Dashboard</button>
    <button onclick="show('courses')">Courses</button>
    <button onclick="show('ai')">AI Tutor</button>
    <button onclick="show('payment')">Payment</button>
  </div>

  <div class="main">

    <div id="dashboard" class="page">
      <div class="card">
        <h2>Welcome</h2>
        <p>Start your AI learning journey</p>
      </div>
    </div>

    <div id="courses" class="page" style="display:none;">
      <div class="card">
        <h3>Courses</h3>
        <div id="courseList"></div>
      </div>
    </div>

    <div id="ai" class="page" style="display:none;">
      <div class="card">
        <h3>AI Tutor</h3>
        <div class="chat" id="chat"></div>
        <textarea id="question"></textarea>
        <button onclick="askAI()">Send</button>
      </div>
    </div>

    <div id="payment" class="page" style="display:none;">
      <div class="card">
        <h3>Payment</h3>
        <p>Each level = ₦500</p>
        <button onclick="pay()">Pay Now</button>
      </div>
    </div>

  </div>

</div>

<script src="app.js"></script>
</body>
</html>const API = "http://localhost:5000/api";

// navigation
function show(page) {
  document.querySelectorAll(".page").forEach(p => p.style.display = "none");
  document.getElementById(page).style.display = "block";
}

// load courses from backend
async function loadCourses() {
  const res = await fetch(API + "/course");
  const data = await res.json();

  const list = document.getElementById("courseList");
  list.innerHTML = "";

  data.forEach(c => {
    list.innerHTML += `
      <div class="card">
        <h4>${c.title}</h4>
        <p>Level: ${c.level}</p>
      </div>
    `;
  });
}

// AI tutor
async function askAI() {
  const input = document.getElementById("question");
  const chat = document.getElementById("chat");

  const msg = input.value;
  if (!msg) return;

  chat.innerHTML += `<div class="user">You: ${msg}</div>`;
  input.value = "";

  const res = await fetch(API + "/ai/ask", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ question: msg })
  });

  const data = await res.json();

  chat.innerHTML += `<div class="ai">AI: ${data.answer}</div>`;
}

// fake payment (next upgrade = Paystack)
function pay() {
  alert("Payment integration coming next step");
}

